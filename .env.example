# Turso Database
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Paddle Payments
# Set to 1 for live mode, 0 for sandbox
PADDLE_LIVE=0

# Sandbox credentials (for testing)
# API Key: from Paddle Dashboard > Developer Tools > Authentication
PADDLE_SANDBOX_API_KEY=
# Webhook Secret: from Paddle Dashboard > Developer Tools > Notifications > Signing Secret
# IMPORTANT: This is the SIGNING SECRET from the notification destination, NOT the API key
PADDLE_SANDBOX_WEBHOOK_SECRET=

# Live credentials (for production)
PADDLE_LIVE_API_KEY=
PADDLE_LIVE_WEBHOOK_SECRET=

# Paddle Client Token (public, safe for client-side)
# Get this from Paddle Dashboard > Checkout > Inline Checkout > Client Side Token
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# Starter Plan
PADDLE_STARTER_PRODUCT_ID=
PADDLE_STARTER_MONTHLY_PRICE_ID=
PADDLE_STARTER_ANNUAL_PRICE_ID=

# Pro Plan
PADDLE_PRO_PRODUCT_ID=
PADDLE_PRO_MONTHLY_PRICE_ID=
PADDLE_PRO_ANNUAL_PRICE_ID=

# Advanced Plan
PADDLE_ADVANCED_PRODUCT_ID=
PADDLE_ADVANCED_MONTHLY_PRICE_ID=
PADDLE_ADVANCED_ANNUAL_PRICE_ID=

# Email (Resend)
RESEND_API_KEY=
